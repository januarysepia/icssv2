# Copy these values into server environment variables.
# Never commit real passwords or App Passwords.

ICSS_DB_HOST=localhost
ICSS_DB_USER=icss_app
ICSS_DB_PASS=change_me
ICSS_DB_NAME=icss

ICSS_SMTP_HOST=smtp.gmail.com
ICSS_SMTP_PORT=587
ICSS_SMTP_USERNAME=your_email@gmail.com
ICSS_SMTP_PASSWORD=your_16_character_app_password
ICSS_SMTP_ENCRYPTION=tls
ICSS_SMTP_FROM_EMAIL=your_email@gmail.com
ICSS_SMTP_FROM_NAME=ICSS v2 ERP System
ICSS_BOSS_APPROVAL_EMAIL=boss@example.com

# Cloud URL, for example: https://erp.yourcompany.com
ICSS_APP_URL=https://example.com/icssv2
